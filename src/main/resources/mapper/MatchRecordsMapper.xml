<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.qhr.dao.MatchRecordsMapper">

    <resultMap id="MatchRecordsMap" type="com.qhr.model.MatchRecord">
        <id column="id" property="id"/>
        <result column="user_open_id" property="userOpenId"/>
        <result column="enterprise_id" property="enterpriseId"/>
        <result column="intention_id" property="intentionId"/>
        <result column="product_ids" property="productIds"/>
        <result column="match_score" property="matchScore"/>
        <result column="risk_type" property="riskType"/>
        <result column="risk_level" property="riskLevel"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <resultMap id="MatchRecordsVoMap" type="com.qhr.vo.MatchRecords">
        <id column="id" property="id"/>
        <result column="enterprise" property="enterprise"/>
        <result column="applicant" property="applicant"/>
        <result column="products" property="products"
                typeHandler="com.qhr.config.typehandler.MatchProductsTypeHandler"/>
        <result column="riskType" property="riskType"/>
        <result column="riskLevel" property="riskLevel"/>
        <result column="status" property="status"/>
        <result column="matchTime" property="matchTime"/>
    </resultMap>

    <sql id="MatchRecord_Columns">
        id, user_open_id, enterprise_id, intention_id, product_ids, match_score,
        risk_type, risk_level, status, created_at
    </sql>

    <select id="list" parameterType="com.qhr.vo.MatchRecords" resultMap="MatchRecordsVoMap">
        select ymr.id,
        ye.name as enterprise,
        pu.real_name as applicant,
        ymr.product_ids as products,
        ymr.risk_type as riskType,
        ymr.risk_level as riskLevel,
        ymr.status as status,
        ymr.created_at as matchTime
        from z_match_records ymr
        left join jc_users pu on ymr.user_open_id=pu.id
        left join jc_enterprise ye on ymr.enterprise_id=ye.id
        ORDER BY ymr.id DESC
        <if test="offset != null and size != null">
            LIMIT #{offset}, #{size}
        </if>
    </select>
</mapper>
