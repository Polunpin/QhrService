<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.qhr.dao.MatchRecordsMapper">

    <resultMap id="MatchRecordsMap" type="com.qhr.model.MatchRecord">
        <constructor>
            <idArg column="id" javaType="java.lang.Long" name="id"/>
            <arg column="user_open_id" javaType="java.lang.String" name="userOpenId"/>
            <arg column="enterprise_id" javaType="java.lang.Long" name="enterpriseId"/>
            <arg column="intention_id" javaType="java.lang.Long" name="intentionId"/>
            <arg column="product_ids" javaType="java.lang.String" name="productIds"/>
            <arg column="match_score" javaType="java.math.BigDecimal" name="matchScore"/>
            <arg column="risk_type" javaType="java.lang.String" name="riskType"/>
            <arg column="risk_level" javaType="java.lang.String" name="riskLevel"/>
            <arg column="status" javaType="java.lang.String" name="status"/>
            <arg column="created_at" javaType="java.time.LocalDateTime" name="createdAt"/>
        </constructor>
    </resultMap>

    <resultMap id="MatchRecordsVoMap" type="com.qhr.vo.MatchRecords">
        <id column="id" property="id"/>
        <result column="enterprise" property="enterprise"/>
        <result column="applicant" property="applicant"/>
        <result column="products" property="products"
                typeHandler="com.qhr.config.typehandler.MatchProductsTypeHandler"/>
        <result column="riskType" property="riskType"/>
        <result column="riskLevel" property="riskLevel"/>
        <result column="status" property="status"/>
        <result column="matchTime" property="matchTime"/>
    </resultMap>

    <sql id="MatchRecord_Columns">
        id, user_open_id, enterprise_id, intention_id, product_ids, match_score,
        risk_type, risk_level, status, created_at
    </sql>

    <select id="list" parameterType="com.qhr.vo.MatchRecords" resultMap="MatchRecordsVoMap">
        select ymr.id,
        ye.name as enterprise,
        pu.real_name as applicant,
        ymr.product_ids as products,
        ymr.risk_type as riskType,
        ymr.risk_level as riskLevel,
        ymr.status as status,
        ymr.created_at as matchTime
        from z_match_records ymr
        left join jc_users pu on ymr.user_open_id=pu.id
        left join jc_enterprise_basic_info ye on ymr.enterprise_id=ye.id
        <where>
            <if test="enterpriseId != null">AND ymr.enterprise_id = #{enterpriseId}</if>
            <if test="intentionId != null">AND ymr.intention_id = #{intentionId}</if>
            <if test="status != null and status != ''">AND ymr.status = #{status}</if>
        </where>
        ORDER BY ymr.id DESC
        <if test="offset != null and size != null">
            LIMIT #{offset}, #{size}
        </if>
    </select>
</mapper>
