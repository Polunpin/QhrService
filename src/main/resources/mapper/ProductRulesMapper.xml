            <arg column="gs_min_registered_capital" javaType="java.math.BigDecimal" name="gsMinRegisteredCapital"/>
            <arg column="gs_min_paid_in_capital" javaType="java.math.BigDecimal" name="gsMinPaidInCapital"/>
