            <arg column="jud_reject_if_executed" javaType="java.lang.Integer" name="judRejectIfExecuted"/>
            <arg column="jud_reject_if_dishonest_person" javaType="java.lang.Integer" name="judRejectIfDishonestPerson"/>
            <arg column="jud_reject_if_equity_frozen" javaType="java.lang.Integer" name="judRejectIfEquityFrozen"/>
            <arg column="jud_max_execution_count_24m" javaType="java.lang.Integer" name="judMaxExecutionCount24m"/>
