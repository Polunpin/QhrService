<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.qhr.dao.CreditProductsMapper">

    <resultMap id="CreditProductsMap" type="com.qhr.model.Product">
        <constructor>
            <idArg column="id" javaType="java.lang.Long" name="id"/>
            <arg column="bank_name" javaType="java.lang.String" name="bankName"/>
            <arg column="product_name" javaType="java.lang.String" name="productName"/>
            <arg column="product_type" javaType="java.lang.String" name="productType"/>
            <arg column="min_amount" javaType="java.math.BigDecimal" name="minAmount"/>
            <arg column="max_amount" javaType="java.math.BigDecimal" name="maxAmount"/>
            <arg column="interest_rate_range" javaType="java.lang.String" name="interestRateRange"/>
            <arg column="loan_term" javaType="java.lang.Integer" name="loanTerm"/>
            <arg column="credit_validity" javaType="java.lang.Integer" name="creditValidity"/>
            <arg column="disbursement_account" javaType="java.lang.String" name="disbursementAccount"/>
            <arg column="scene" javaType="java.lang.Integer" name="scene"/>
            <arg column="online" javaType="java.lang.Integer" name="online"/>
            <arg column="repayment_method" javaType="java.lang.String" name="repaymentMethod"/>
            <arg column="status" javaType="java.lang.Integer" name="status"/>
            <arg column="created_at" javaType="java.time.LocalDateTime" name="createdAt"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime" name="updatedAt"/>
        </constructor>
    </resultMap>

    <sql id="CreditProduct_Columns">
        id, bank_name, product_name, product_type, min_amount, max_amount, interest_rate_range,
        loan_term, credit_validity, disbursement_account, scene, online, repayment_method, status,
        created_at, updated_at
    </sql>

    <select id="list" resultMap="CreditProductsMap">
        SELECT <include refid="CreditProduct_Columns"/>
        FROM jc_products
        <where>
            <if test="status != null"> AND status = #{status}</if>
            <if test="productType != null and productType != ''"> AND product_type = #{productType}</if>
            <if test="bankName != null and bankName != ''"> AND bank_name LIKE CONCAT('%', #{bankName}, '%')</if>
        </where>
        ORDER BY id DESC
        <if test="offset != null and size != null">
            LIMIT #{offset}, #{size}
        </if>
    </select>

</mapper>
