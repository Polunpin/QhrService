<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.qhr.dao.CreditProductsMapper">

    <resultMap id="CreditProductsMap" type="com.qhr.model.Product">
        <id column="id" property="id"/>
        <result column="bank_name" property="bankName"/>
        <result column="product_name" property="productName"/>
        <result column="product_type" property="productType"/>
        <result column="min_amount" property="minAmount"/>
        <result column="max_amount" property="maxAmount"/>
        <result column="interest_rate_range" property="interestRateRange"/>
        <result column="loan_term" property="loanTerm"/>
        <result column="credit_validity" property="creditValidity"/>
        <result column="disbursement_account" property="disbursementAccount"/>
        <result column="scene" property="scene"/>
        <result column="online" property="online"/>
        <result column="repayment_method" property="repaymentMethod"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="CreditProduct_Columns">
        id, bank_name, product_name, product_type, min_amount, max_amount, interest_rate_range,
        loan_term, credit_validity, disbursement_account, scene, online, repayment_method, status,
        created_at, updated_at
    </sql>

    <select id="list" resultMap="CreditProductsMap">
        SELECT <include refid="CreditProduct_Columns"/>
        FROM jc_products
        <where>
            <if test="status != null"> AND status = #{status}</if>
            <if test="productType != null and productType != ''"> AND product_type = #{productType}</if>
            <if test="bankName != null and bankName != ''"> AND bank_name LIKE CONCAT('%', #{bankName}, '%')</if>
        </where>
        ORDER BY id DESC
        <if test="offset != null and size != null">
            LIMIT #{offset}, #{size}
        </if>
    </select>

</mapper>
