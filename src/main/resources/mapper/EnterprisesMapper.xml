<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.qhr.dao.EnterprisesMapper">

    <resultMap id="EnterprisesMap" type="com.qhr.model.Enterprise">
        <constructor>
            <idArg column="id" javaType="java.lang.Long" name="id"/>
            <arg column="name" javaType="java.lang.String" name="name"/>
            <arg column="credit_code" javaType="java.lang.String" name="creditCode"/>
            <arg column="start_date" javaType="java.lang.String" name="startDate"/>
            <arg column="oper_name" javaType="java.lang.String" name="operName"/>
            <arg column="status" javaType="java.lang.String" name="status"/>
            <arg column="address" javaType="java.lang.String" name="address"/>
            <arg column="created_at" javaType="java.time.LocalDateTime" name="createdAt"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime" name="updatedAt"/>
        </constructor>
    </resultMap>

    <sql id="Enterprise_Columns">
        id, name, credit_code, start_date, oper_name, status, address, created_at, updated_at
    </sql>

    <select id="list" resultMap="EnterprisesMap">
        SELECT <include refid="Enterprise_Columns"/>
        FROM jc_enterprise_basic_info
        <where>
            <if test="name != null and name != ''"> AND name LIKE CONCAT('%', #{name}, '%')</if>
            <if test="creditCode != null and creditCode != ''"> AND credit_code = #{creditCode}</if>
            <if test="operName != null and operName != ''"> AND oper_name LIKE CONCAT('%', #{operName}, '%')</if>
            <if test="status != null and status != ''"> AND status = #{status}</if>
        </where>
        ORDER BY id DESC
        <if test="offset != null and size != null">
            LIMIT #{offset}, #{size}
        </if>
    </select>

    <select id="listByUserId" resultMap="EnterprisesMap">
        SELECT e.id, e.name, e.credit_code, e.start_date, e.oper_name, e.status,
               e.address, e.created_at, e.updated_at
        FROM jc_enterprise_basic_info e
        JOIN zj_user_enterprise_relation r ON e.id = r.enterprise_id
        WHERE r.user_id = #{userId}
        ORDER BY e.id DESC
        <if test="offset != null and size != null">
            LIMIT #{offset}, #{size}
        </if>
    </select>

</mapper>
