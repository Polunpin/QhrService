<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.qhr.dao.StaffsMapper">

    <resultMap id="StaffsMap" type="com.qhr.model.Staff">
        <constructor>
            <idArg column="id" javaType="java.lang.Long" name="id"/>
            <arg column="openid" javaType="java.lang.String" name="openid"/>
            <arg column="real_name" javaType="java.lang.String" name="realName"/>
            <arg column="mobile" javaType="java.lang.String" name="mobile"/>
            <arg column="role" javaType="java.lang.String" name="role"/>
            <arg column="department" javaType="java.lang.String" name="department"/>
            <arg column="status" javaType="java.lang.Integer" name="status"/>
            <arg column="last_update_at" javaType="java.time.LocalDateTime" name="lastUpdateAt"/>
            <arg column="created_at" javaType="java.time.LocalDateTime" name="createdAt"/>
        </constructor>
    </resultMap>

    <sql id="Staff_Columns">
        id, openid, real_name, mobile, role, department, status, last_update_at, created_at
    </sql>

    <select id="list" parameterType="com.qhr.vo.Staffs">
        SELECT id,
        real_name as name,
        mobile as phone,
        role,
        department,
        status,
        last_update_at as lastLogin
        FROM jc_staffs
        ORDER BY id DESC
        <if test="offset != null and size != null">
            LIMIT #{offset}, #{size}
        </if>
    </select>
</mapper>
